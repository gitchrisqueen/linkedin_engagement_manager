# =============================================================================
# Core Application
# =============================================================================
TZ=America/New_York
API_PORT=8000
CQC_LEM_CHECK_SCHEDULE_DELTA_MINUTES=5
CQC_LEM_POST_TIME_DELTA_MINUTES=20


# =============================================================================
# Database (MySQL)
# =============================================================================
MYSQL_ROOT_PASSWORD=your_root_password
MYSQL_USER=your_db_user
MYSQL_PASSWORD=your_db_password
MYSQL_DATABASE=linkedin_manager
MYSQL_PORT=3306
# Matches the service name in docker-compose
MYSQL_HOST=mysql_db


# =============================================================================
# Cache & Task Queue (Redis + Celery)
# =============================================================================
REDIS_PORT=6379

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_BROKER_CONNECTION_RETRY_ON_STARTUP=True
CELERY_RESULT_EXTENDED=True
CELERY_FLOWER_PORT=8555
CELERY_FLOWER_PASSWORD=your_flower_password
CELERY_FLOWER_STATE_SAVE_INTERVAL=5000
CELERY_WORKER_HOST=celery-worker-host
CELERY_WORKER_NAME=worker@%h


# =============================================================================
# LinkedIn API
# =============================================================================
LI_CLIENT_ID=your_linkedin_client_id
LI_CLIENT_SECRET=your_linkedin_client_secret
# LI_REDIRECT_URL is auto-overridden by NGROK_CUSTOM_DOMAIN when set (see env_constants.py)
LI_REDIRECT_URL=https://your.domain.com/auth/linkedin/callback
LI_STATE_SALT=your_state_salt_string
LI_API_VERSION=202501
LI_USERINFO_RESOURCE=/userinfo
LI_POSTS_RESOURCE=/posts

# Deprecated in favor of OAuth — kept for reference and potential future non-OAuth flows
# LI_USER=your_email@example.com
# LI_PASSWORD=your_linkedin_password


# =============================================================================
# AI / LLM Providers
# =============================================================================

# --- LiteLLM (proxy/routing) ---
LITELLM_MASTER_KEY=your_litellm_master_key
LITELLM_BASE_URL=http://litellm:4000
# Uncomment to use LiteLLM outside of Docker
# LITELLM_BASE_URL=http://localhost:4000

# --- OpenAI ---
OPENAI_API_KEY=your_openai_api_key

# --- Anthropic (Claude) ---
# ANTHROPIC_API_KEY=your_anthropic_api_key

# --- OpenRouter ---
OPENROUTER_API_KEY=your_openrouter_api_key

# --- Perplexity (advanced search / RAG) ---
PERPLEXITY_API_KEY=your_perplexity_api_key

# --- Ollama (local + cloud model hosting) ---
OLLAMA_API_KEY=your_ollama_api_key
OLLAMA_CLOUD_API_KEY=your_ollama_cloud_api_key
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# Cloud URL requires /v1 suffix for OpenAI compatibility (supports streaming + tool calling)
OLLAMA_CLOUD_URL=https://ollama.com/v1


# =============================================================================
# Image / Video Generation
# =============================================================================

# --- Pexels (stock photos/videos) ---
PEXELS_API_KEY=your_pexels_api_key

# --- Hugging Face (must be named HF_TOKEN for auto-login) ---
HF_TOKEN=your_huggingface_token

# --- Replicate ---
REPLICATE_API_TOKEN=your_replicate_api_token
REPLICATE_USERNAME=your_replicate_username

# --- RunwayML ---
RUNWAYML_API_SECRET=your_runwayml_api_secret


# =============================================================================
# Billing (Stripe)
# =============================================================================
FREE_TRIAL_DAYS=14

# --- Stripe Test (use sk_test_* keys for test mode) ---
STRIPE_API_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
# Price IDs created in Stripe dashboard under Products → Pricing
STRIPE_PRICE_ID_STARTER=price_your_starter_price_id
STRIPE_PRICE_ID_PROFESSIONAL=price_your_professional_price_id
STRIPE_PRICE_ID_ENTERPRISE=price_your_enterprise_price_id

# --- Stripe Production (use sk_live_* keys for production) ---
# IMPORTANT: Use the webhook signing secret from your Stripe dashboard for the
# environment you're using (test or live) to ensure webhook security.
# STRIPE_API_KEY=sk_live_your_stripe_secret_key
# STRIPE_WEBHOOK_SECRET=whsec_your_live_webhook_signing_secret
# STRIPE_PRICE_ID_STARTER=price_your_live_starter_price_id
# STRIPE_PRICE_ID_PROFESSIONAL=price_your_live_professional_price_id
# STRIPE_PRICE_ID_ENTERPRISE=price_your_live_enterprise_price_id


# =============================================================================
# Email / Notifications
# =============================================================================

# --- SendGrid (transactional email) ---
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=no-reply@yourdomain.com

# --- SMTP fallback (Gmail App Password — not your regular password) ---
# Get an App Password at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password


# =============================================================================
# Observability & CI
# =============================================================================

# --- PostHog (analytics) ---
POSTHOG_API_KEY=your_posthog_api_key
POSTHOG_HOST=https://us.i.posthog.com
# Minimum log level forwarded to PostHog (DEBUG/INFO/WARNING/ERROR/CRITICAL). Default: ERROR
POSTHOG_LOG_LEVEL=ERROR

# --- Codecov (coverage reporting) ---
CODECOV_TOKEN=your_codecov_token

# --- GitGuardian (secret scanning) ---
GITGUARDIAN_API_KEY=your_gitguardian_api_key


# =============================================================================
# Tunnel & Networking (Ngrok)
# =============================================================================
# NGROK_PLAN controls tunnel behavior:
#   off  — ngrok is disabled (default for new setups)
#   free — one static domain (NGROK_CUSTOM_DOMAIN) for the app; other tunnels get dynamic random URLs
#   paid — all services get custom subdomains (requires a paid ngrok plan)
NGROK_PLAN=off
NGROK_AUTH_TOKEN=your_ngrok_auth_token
NGROK_CUSTOM_DOMAIN=your-subdomain.ngrok-free.dev
# NGROK_CUSTOM_DOMAIN=your_custom_domain.yourdomain.com
# NGROK_EDGE_TOKEN=your_ngrok_edge_token
NGROK_FREE_DOMAIN=ngrok-free.dev
NGROK_UI_PORT=4040
NGROK_API_PREFIX=your-app-api
NGROK_FLOWER_PREFIX=your-app-flower
NGROK_CHROME_PREFIX=your-app-chrome
NGROK_LIPREVIEW_PREFIX=your-app-lipreview
NGROK_JAEGER_PREFIX=your-app-jaeger


# =============================================================================
# Browser Automation (Selenium)
# =============================================================================
SELENIUM_HUB_HOST=selenium-chrome
SELENIUM_HUB_PORT=4444
SELENIUM_KEEP_VIDEOS_X_DAYS=7


# =============================================================================
# Docker
# =============================================================================
DOCKER_IMAGE_NAME=your_dockerhub_username/your_image_name


# =============================================================================
# Cloud Infrastructure (AWS)
# =============================================================================
# AWS_ACCOUNT_ID=your_aws_account_id
# AWS_REGION=us-east-1
# AWS_API_KEY=your_aws_api_key
# AWS_APPLICATION_NAME=your-app-name
# AWS_APPLICATION_TAG=your-app-tag
# AWS_ENV_TAG=dev
# CDK_VERSION=2.1000.2
# AWS_ACCESS_KEY_ID=your_aws_access_key_id
# AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# For testing AWS resource access locally or in local Docker:
# AWS_MYSQL_SECRET_NAME=your_mysql_secret_name
# AWS_SQS_SECRET_NAME=your_sqs_secret_name
# AWS_SQS_QUEUE_NAME=your_sqs_queue_name
# AWS_SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/your_account_id/your_queue_name


# =============================================================================
# Dev & Debug
# =============================================================================
INSTALL_DEV_DEPS=false
PURGE_TASKS=True
CLEAR_SELENIUM_SESSIONS=True

# --- Streamlit ---
STREAMLIT_EMAIL=your_email@example.com
STREAMLIT_PORT=8501

# --- Code Tracing ---
# CODE_TRACING=True

# --- Jaeger (removed from docker-compose; kept for reference) ---
# JAEGER_AGENT_HOST=error_tracing
# JAEGER_SPANS_HTTP_PORT=4318
# JAEGER_SPANS_GRPC_PORT=4317
# JAEGER_SAMPLE_COLLECTOR_GRPC_PORT=14250
# JAEGER_METRICS_COLLECTION_PORT=14269
# JAEGER_UI_PORT=8666

# --- Prometheus (removed from docker-compose; kept for reference) ---
# PROMETHEUS_HOST=prometheus
# PROMETHEUS_PORT=9090
